<Window x:Class="StartZapret.WindowPath"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StartZapret"
        mc:Ignorable="d"
        Title="WindowPath"
        Height="100" 
        Width="400"
        Background="Gray"
        >
    
    <Grid>
        <TextBlock x:Name="textBlockX" Foreground="White" Height="20" Width="100" VerticalAlignment="Top" HorizontalAlignment="Left"  ></TextBlock>
        <TextBox Background="DimGray" x:Name="boxPath" Height="20" Width="300" VerticalAlignment="Top" HorizontalAlignment="Right"></TextBox>
        <Button Background="Black" Foreground="White" x:Name="btnSave" HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="30" Height="30" Content="Save"> </Button>
    </Grid>
</Window>
