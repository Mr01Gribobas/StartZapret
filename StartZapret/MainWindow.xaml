<Window x:Class="StartZapret.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StartZapret"
        xmlns:AppManager="clr-namespace:StartZapret.ControllerApplication" 
        mc:Ignorable="d"
        Height="350" 
        Width="400"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"       
        >
    <Window.Resources>
    <Style x:Key="StyleResources">
            <Setter Property="Control.Opacity" Value="0.3"></Setter>
            <Setter Property="Control.Background" Value="DimGray"></Setter>
            <Style.Triggers>
                <Trigger Property="Control.Opacity" Value="0.4">
                    <Setter Property="Control.Background" Value="Blue"/>
                </Trigger>
                <Trigger Property="Control.Opacity" Value="0.3">
                    <Setter Property="Control.Background" Value="BlueViolet"/>
                </Trigger>
            </Style.Triggers>
        
    </Style>

    </Window.Resources>
        

    <Grid Background="Gray" Opacity="1.3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
        <Button 
            x:Name="ButtonClose"
            Width="20"
            Height="20"
            Content="X"            
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Click="Close_click"
            Grid.Column="2"   
            
            >
            


        </Button>
        <Image             
            x:Name="ImageZapret"              
            Grid.Column="0" 
            Grid.Row="1"
            Opacity="{Binding OpacityPropyrty }"
            
            >
            <Image.Source>
                <FormatConvertedBitmap  Source="/Source/Images/images.jpeg" DestinationFormat="Gray32Float"/>
            </Image.Source>
        </Image>
        <Image            
            x:Name="ImageVk" 
            Grid.Column="1" 
            Grid.Row="1"
            Opacity="{Binding OpacityPropyrty }">
            <Image.Source>
                <FormatConvertedBitmap Source="/Source/Images/vkImage.png" DestinationFormat="Gray32Float"></FormatConvertedBitmap>
            </Image.Source>
        </Image>
        <Image            
    x:Name="ImageDis" 
    Grid.Column="2" 
    Grid.Row="1"
    Opacity="{Binding OpacityPropyrty }">
            <Image.Source>
                <FormatConvertedBitmap Source="/Source/Images/disImage.jpg" DestinationFormat="Gray32Float"></FormatConvertedBitmap>
            </Image.Source>
        </Image>


            
        <Border
            BorderThickness="2"
            BorderBrush="Black"
            CornerRadius="50"
            Grid.Column="1"
            Grid.Row="2">
        <Button Command="{Binding My_command}"
                Width="100"
                Height="100"
                BorderThickness="9"
            Style="{StaticResource ResourceKey = StyleResources }"
             Opacity="{Binding OpacityPropyrty }" 
                Content="Reset"
                
                ></Button>
        </Border>
    </Grid>

</Window>
